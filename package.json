{
  "name": "stati",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "ios:release:device": "react-native run-ios --mode Release --device=\"Dawid's iPhone\"",
    "ios:release:simulator": "react-native run-ios --mode Release --simulator='iPhone 15 Pro'",
    "ios:dev:device": "react-native run-ios --mode Debug --device=\"Dawid's iPhone\"",
    "ios:dev:simulator": "react-native run-ios --mode Debug --simulator='iPhone 15 Pro'",
    "android:dev": "react-native run-android --mode=debug",
    "ios:clean": "cd ios && xcodebuild clean",
    "pod:install": "cd ios && pod install --repo-update",
    "pod:clean": "cd ios && rm -rf Pods && rm -rf Podfile.lock && pod cache clean --all",
    "android:clean": "cd android && ./gradlew clean",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "start": "react-native start",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "dependencies": {
    "@apollo/client": "^3.9.11",
    "@gorhom/bottom-sheet": "^4",
    "@react-native-async-storage/async-storage": "^1.21.0",
    "@react-native-community/netinfo": "6.0.0",
    "@react-native-firebase/app": "^19.2.2",
    "@react-native-firebase/messaging": "^19.2.2",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/material-bottom-tabs": "^6.2.20",
    "@react-navigation/material-top-tabs": "^6.6.6",
    "@react-navigation/native": "^6.1.10",
    "@react-navigation/native-stack": "^6.9.17",
    "add": "^2.0.6",
    "babel-plugin-module-resolver": "^5.0.0",
    "base-64": "^1.0.0",
    "graphql": "^16.8.1",
    "lottie-react-native": "^6.7.0",
    "react": "18.2.0",
    "react-native": "^0.73.6",
    "react-native-bootsplash": "^5.5.3",
    "react-native-config": "^1.5.1",
    "react-native-device-info": "^10.13.2",
    "react-native-fast-image": "^8.6.3",
    "react-native-gesture-handler": "^2.15.0",
    "react-native-hyperlink": "^0.0.22",
    "react-native-inappbrowser-reborn": "^3.7.0",
    "react-native-pager-view": "^6.2.3",
    "react-native-screens": "^3.29.0",
    "react-native-svg": "^14.1.0",
    "react-native-tab-view": "^3.5.2",
    "react-native-vector-icons": "^10.0.3",
    "yarn": "^1.22.21",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@graphql-codegen/cli": "5.0.2",
    "@graphql-codegen/client-preset": "4.2.5",
    "@graphql-codegen/introspection": "4.0.3",
    "@react-native/babel-preset": "^0.73.18",
    "@react-native/eslint-config": "^0.73.1",
    "@react-native/metro-config": "^0.73.2",
    "@react-native/typescript-config": "^0.73.1",
    "@types/base-64": "^1.0.2",
    "@types/react": "^18.2.6",
    "@types/react-test-renderer": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "8.57.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "5.0.0",
